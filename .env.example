# ─── Database ───────────────────────────────────────────────
# Fill in with your own PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Example (Supabase): postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
# Example (Neon):     postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# Example (local):    postgresql://postgres:password@localhost:5432/stacknote
DATABASE_URL=""
DIRECT_URL=""

# ─── Auth ───────────────────────────────────────────────────
# Generate a strong random secret: run `openssl rand -base64 32` in your terminal
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# ─── Email (magic links) ────────────────────────────────────
# Get your API key at https://resend.com — free tier is enough for development
RESEND_API_KEY=""

# ─── Google OAuth ───────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Supabase Storage ────────────────────────────────────────
# Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Server only. Do not expose to the client.
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Cover search (Unsplash) ────────────────────────────────
# Create an app at https://unsplash.com/developers
# Used server-side to search note cover images.
UNSPLASH_ACCESS_KEY=""

# ─── GROQ API Key (for search) ───────────────────────────────
# Get your API key at https://groq.com — free tier is enough for development
GROQ_API_KEY=""