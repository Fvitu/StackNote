generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String?
  image          String?
  emailVerified  DateTime?
  isGuest        Boolean         @default(false)
  guestLastActiveAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  sessions       Session[]
  workspaces     Workspace[]
  files          File[]
  aiUsage        AIUsage[]
  aiQuotaWindows AIQuotaWindow[]
  aiChatSessions AIChatSession[]
  aiMessages     AIMessage[]
  flashcardDecks FlashcardDeck[]
  settings       UserSettings?
  quickNote      QuickNote?
  studySessions  StudySession[]
  exams          Exam[]

  @@index([isGuest, guestLastActiveAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  folders   Folder[]
  notes     Note[]
  aiChatSessions AIChatSession[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("workspaces")
}

model Folder {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  parentId    String?
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  parent      Folder?   @relation("FolderChildren", fields: [parentId], references: [id])
  children    Folder[]  @relation("FolderChildren")
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  notes       Note[]

  @@map("folders")
}

model Note {
  id             String          @id @default(cuid())
  title          String          @default("Untitled")
  content        Json?
  workspaceId    String
  folderId       String?
  emoji          String?
  coverImage     String?
  coverImageMeta Json?
  isArchived     Boolean         @default(false)
  order          Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  versions       NoteVersion[]
  files          File[]
  aiMessages     AIMessage[]
  aiChatSessions AIChatSession[]
  flashcardDecks FlashcardDeck[]
  searchVector   Unsupported("tsvector")?
  folder         Folder?         @relation(fields: [folderId], references: [id])
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([searchVector], type: Gin)
  @@map("notes")
}

model NoteVersion {
  id        String   @id @default(cuid())
  noteId    String
  content   Json
  createdAt DateTime @default(now())
  manual    Boolean  @default(false)
  label     String?
  note      Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@map("note_versions")
}

model File {
  id        String   @id @default(cuid())
  noteId    String
  userId    String
  name      String
  type      String
  mimeType  String
  size      Int
  path      String
  url       String
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("files")
}

model AIUsage {
  id           String   @id @default(cuid())
  userId       String
  date         String   // "YYYY-MM-DD" format — resets daily
  textTokens   Int      @default(0)
  sttMinutes   Float    @default(0)
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("ai_usage")
}

model AIQuotaWindow {
  id              String   @id @default(cuid())
  userId          String
  category        String
  modelKey        String
  windowStartedAt DateTime
  windowEndsAt    DateTime
  requestCount    Int      @default(0)
  tokenCount      Int      @default(0)
  flashcardCount  Int      @default(0)
  audioSeconds    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, modelKey])
  @@index([userId, category, modelKey, windowEndsAt])
  @@map("ai_quota_windows")
}

model AIMessage {
  id         String         @id @default(cuid())
  userId     String
  sessionId  String?
  noteId     String?
  role       String         // "user" | "assistant"
  content    String         @db.Text
  model      String
  tokensUsed Int            @default(0)
  createdAt  DateTime       @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  session AIChatSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  note    Note?         @relation(fields: [noteId], references: [id], onDelete: SetNull)

  @@index([sessionId, createdAt])
  @@map("ai_messages")
}

model AIChatSession {
  id             String      @id @default(cuid())
  userId         String
  workspaceId    String
  noteId         String?
  title          String      @default("New chat")
  contextNoteIds String[]
  lastMessageAt  DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  note      Note?         @relation(fields: [noteId], references: [id], onDelete: SetNull)
  messages  AIMessage[]

  @@index([userId, workspaceId, noteId, lastMessageAt])
  @@map("ai_chat_sessions")
}

model Flashcard {
  id         String        @id @default(cuid())
  deckId     String
  front      String        @db.Text
  back       String        @db.Text
  stability  Float         @default(0)
  difficulty Float         @default(0)
  reps       Int           @default(0)
  lapses     Int           @default(0)
  state      Int           @default(0) // 0=new, 1=learning, 2=review, 3=relearning
  dueDate    DateTime      @default(now())
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  deck    FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews CardReview[]

  @@map("flashcards")
}

model FlashcardDeck {
  id          String      @id @default(cuid())
  userId      String
  noteId      String?
  title       String
  description String?
  cardCount   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  note          Note?          @relation(fields: [noteId], references: [id], onDelete: SetNull)
  flashcards    Flashcard[]
  studySessions StudySession[]

  @@map("flashcard_decks")
}

model UserSettings {
  id                 String @id @default(cuid())
  userId             String @unique
  preferredTextModel String @default("openai/gpt-oss-120b")
  preferredSttModel  String @default("whisper-large-v3")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model StudySession {
  id           String       @id @default(cuid())
  userId       String
  deckId       String
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  cardsStudied Int          @default(0)
  cardsCorrect Int          @default(0)
  totalTime    Int          @default(0)

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck    FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  reviews CardReview[]

  @@map("study_sessions")
}

model CardReview {
  id        String       @id @default(cuid())
  sessionId String
  cardId    String
  rating    Int
  timeMs    Int
  createdAt DateTime     @default(now())

  session StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card    Flashcard    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@map("card_reviews")
}

model Exam {
  id                String         @id @default(cuid())
  userId            String
  title             String
  subject           String?
  examDate          DateTime
  noteIds           String[]
  deckIds           String[]
  dailyStudyMinutes Int            @default(20)
  isCompleted       Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyPlanDays StudyPlanDay[]

  @@map("exams")
}

model StudyPlanDay {
  id               String   @id @default(cuid())
  examId           String
  date             String
  cardIds          String[]
  estimatedMinutes Int      @default(0)
  isCompleted      Boolean  @default(false)

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("study_plan_days")
}

model QuickNote {
  id        String   @id @default(cuid())
  userId    String   @unique
  content   Json?
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("quick_notes")
}
